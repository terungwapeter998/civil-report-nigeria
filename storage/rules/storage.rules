rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    /**
     * =========================================================
     * SHARED INVARIANTS (FAIL-CLOSED AUTH MODEL)
     * =========================================================
     */
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated()
        && request.auth.uid == userId;
    }

    function isValidTenant(tenantId) {
      return isAuthenticated()
        && request.auth.token.tenantId == tenantId;
    }

    function isAdmin() {
      return isAuthenticated()
        && request.auth.token.roles.hasAny(['admin']);
    }

    /**
     * =========================================================
     * LEDGER (CRYPTOGRAPHIC STATE MACHINE STORAGE)
     * =========================================================
     */
    match /ledger/{tenantId}/events/{eventId} {

      allow read: if isValidTenant(tenantId) || isAdmin();

      allow create: if isValidTenant(tenantId)

        // STRICT TENANT BINDING (NO OPTIONALITY)
        && request.resource.data.tenantId == tenantId

        // STRICT ACTOR BINDING
        && request.resource.data.actor == request.auth.uid

        // STRUCTURAL INVARIANT (NOT JUST KEY PRESENCE)
        && request.resource.data.keys().hasAll([
          "type",
          "payload",
          "actor",
          "seq",
          "hash",
          "prevHash",
          "tenantId"
        ])

        // CRITICAL: ENSURE IMMUTABLE EVENT TYPE CONTRACT
        && request.resource.data.type is string
        && request.resource.data.seq is int

        // CRYPTOGRAPHIC SANITY CHECK (MINIMAL GUARD, NOT VALIDATION)
        && request.resource.data.hash is string
        && request.resource.data.prevHash is string;

      allow update, delete: if false;
    }

    /**
     * =========================================================
     * TENANT DATA (STRICT ISOLATION, NO IMPLICIT BINDING)
     * =========================================================
     */
    match /tenants/{tenantId}/{document=**} {

      allow read: if isValidTenant(tenantId) || isAdmin();

      allow create, update: if isValidTenant(tenantId)
        && request.resource.data.tenantId == tenantId;

      allow delete: if isAdmin();
    }

    /**
     * =========================================================
     * USERS (LEDGER-ALIGNED IDENTITY MODEL)
     * =========================================================
     */
    match /users/{userId} {

      allow read: if isOwner(userId) || isAdmin();

      // USER STATE MUST BE AUDITED THROUGH LEDGER EVENTS
      allow create, update: if false;

      allow delete: if false;
    }

    /**
     * =========================================================
     * GLOBAL FAIL-CLOSE
     * =========================================================
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}