# =========================================================
# STAGE 6 ENVIRONMENT CONTRACT
# =========================================================
# This file defines ONLY configuration shape.
# NO REAL VALUES. NO PRODUCTION DETAILS.
# =========================================================


# =========================
# CORE FIREBASE IDENTITY
# =========================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"


# =========================
# SECURITY & CRYPTOGRAPHY
# =========================
HASH_ALGORITHM=sha256
LEDGER_MODE=append_only
CANONICAL_SERIALIZATION=recursive_sorted_json
ENABLE_DETERMINISTIC_CLOCK=true


# =========================
# TENANT ISOLATION MODEL
# =========================
TENANT_STRICT_MODE=true
ALLOW_CROSS_TENANT=false


# =========================
# LOGICAL CLOCK SYSTEM
# =========================
CLOCK_MODE=injected
CLOCK_SOURCE=system|external|mock


# =========================
# AUTH CONFIGURATION
# =========================
AUTH_PROVIDER=firebase
TOKEN_MODE=jwt
ROLE_CLAIM_PATH=roles


# =========================
# LEDGER CONFIGURATION
# =========================
LEDGER_COLLECTION=ledger
LEDGER_EVENT_COLLECTION=events
LEDGER_IMMUTABILITY=true
LEDGER_REPLAY_MODE=strict


# =========================
# EVIDENCE SYSTEM
# =========================
EVIDENCE_COLLECTION=evidence
EVIDENCE_MODE=forensic_append_only
EVIDENCE_HASH_REQUIRED=true


# =========================
# DEPLOYMENT ENVIRONMENT
# =========================
NODE_ENV=development
LOG_LEVEL=info
STRICT_FAIL_CLOSED=true


# =========================
# OBSERVABILITY (NO SENSITIVE DATA)
# =========================
ENABLE_AUDIT_LOGS=true
ENABLE_TRACE_ID=true
TRACE_ID_STRATEGY=deterministic_hash