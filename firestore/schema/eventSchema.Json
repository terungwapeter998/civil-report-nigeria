{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://civic.system/schemas/event.schema.json",
    "title": "Stage6Event",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "type",
        "payload",
        "actor",
        "tenantId",
        "seq",
        "hash",
        "prevHash"
    ],
    "properties": {
        "type": {
            "type": "string",
            "minLength": 1
        },
        "payload": {
            "type": "object",
            "additionalProperties": true
        },
        "actor": {
            "type": "string",
            "minLength": 1
        },
        "tenantId": {
            "type": "string",
            "minLength": 1
        },
        "seq": {
            "type": "integer",
            "minimum": 0
        },
        "hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
        },
        "prevHash": {
            "type": "string",
            "minLength": 1
        }
    },
    "allOf": [
        /**
     * =========================================================
     * SYSTEM INVARIANT: TENANT BINDING IS NON-NEGOTIABLE
     * =========================================================
     */
        {
            "if": {
                "properties": {
                    "tenantId": {
                        "type": "string"
                    }
                }
            },
            "then": {
                "properties": {
                    "tenantId": {
                        "const": {
                            "$data": "1/tenantId"
                        }
                    }
                }
            }
        }
    ]
}